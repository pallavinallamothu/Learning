{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "LTSSadf"
		},
		"AzureDatabricks1_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'AzureDatabricks1'"
		},
		"ls_adf_gen1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adf_gen1'"
		},
		"ls_sql_utildb_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sql_utildb'"
		},
		"AzureDatabricks1_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0420-100835-h9llbjq3"
		},
		"ls_adf_gen1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://learningsan.dfs.core.windows.net/"
		},
		"ls_sql_utildb_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserverutil.database.windows.net"
		},
		"ls_sql_utildb_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "UTIL"
		},
		"ls_sql_utildb_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "pallavinallamothu"
		},
		"LTSS1trigger_properties_LTSS2_parameters_P2": {
			"type": "int",
			"defaultValue": 5
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "LTSSadf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDatabricks1_accessToken": {
						"value": "[parameters('AzureDatabricks1_accessToken')]"
					},
					"ls_adf_gen1_accountKey": {
						"value": "[parameters('ls_adf_gen1_accountKey')]"
					},
					"ls_sql_utildb_password": {
						"value": "[parameters('ls_sql_utildb_password')]"
					},
					"AzureDatabricks1_properties_typeProperties_existingClusterId": {
						"value": "[parameters('AzureDatabricks1_properties_typeProperties_existingClusterId')]"
					},
					"ls_adf_gen1_properties_typeProperties_url": {
						"value": "[parameters('ls_adf_gen1_properties_typeProperties_url')]"
					},
					"ls_sql_utildb_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_utildb_properties_typeProperties_server')]"
					},
					"ls_sql_utildb_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_utildb_properties_typeProperties_database')]"
					},
					"ls_sql_utildb_properties_typeProperties_userName": {
						"value": "[parameters('ls_sql_utildb_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "LTSSadf_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LTSS1trigger_properties_LTSS2_parameters_P2": {
						"value": "[parameters('LTSS1trigger_properties_LTSS2_parameters_P2')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'LTSSadf_ArmTemplate_0')]"
			]
		}
	]
}